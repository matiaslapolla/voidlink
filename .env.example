DATABASE_URL=postgresql://voidlink:voidlink@localhost:5432/voidlink
CORS_ORIGINS=http://localhost:5173,http://localhost:1420

# Tauri migration engine provider
# openai | groq | openrouter | ollama
VOIDLINK_LLM_PROVIDER=openai

# Provider API keys (set the one that matches VOIDLINK_LLM_PROVIDER)
# OPENAI_API_KEY=
# GROQ_API_KEY=
# OPENROUTER_API_KEY=
# OLLAMA_API_KEY=

# Ollama local defaults (optional)
# VOIDLINK_OLLAMA_BASE_URL=http://localhost:11434/v1
# VOIDLINK_OLLAMA_MODEL=llama3.2
# VOIDLINK_OLLAMA_EMBED_MODEL=nomic-embed-text
