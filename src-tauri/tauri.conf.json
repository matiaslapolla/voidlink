{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "voidlink",
  "version": "0.1.0",
  "identifier": "com.voidlink.app",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../frontend && npm run dev",
    "beforeBuildCommand": "cd ../frontend && npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Voidlink",
        "width": 800,
        "height": 600,
        "minWidth": 820,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "transparent": true,
        "backgroundColor": "#00000000",
        "center": true,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
